{
  "name": "apcore-cli",
  "version": "0.3.2",
  "description": "CLI wrapper for the apcore core SDK — exposes apcore modules as CLI commands",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "apcore-cli": "./dist/bin/apcore-cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "apcore",
    "cli",
    "ai",
    "modules"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "apcore-js": ">=0.14.0",
    "apcore-toolkit": ">=0.4.0"
  },
  "peerDependenciesMeta": {
    "apcore-toolkit": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ajv": "^8.12.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "apdev-js": "^0.2.2",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/js-yaml": "^4.0.0"
  },
  "apdev": {
    "base_package": "apcore-cli"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}